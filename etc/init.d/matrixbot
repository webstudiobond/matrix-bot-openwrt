#!/bin/sh /etc/rc.common

START=99
USE_PROCD=1

SCRIPT="/usr/lib/matrix/matrix_bot"

start_service() {
    if [ ! -f "$SCRIPT" ]; then
        logger -t matrixbot "ERROR: $SCRIPT not found, refusing to start"
        return 1
    fi

    procd_open_instance
    procd_set_param command /bin/sh "$SCRIPT" --e2ee

    # respawn <failure_threshold_secs> <restart_delay_secs> <max_failures_0=infinite>
    procd_set_param respawn 3600 5 0

    # Forward stdout/stderr to logread via procd
    procd_set_param stdout 1
    procd_set_param stderr 1

    procd_close_instance
}

stop_service() {
    logger -t matrixbot "Stopping matrix_bot"
}
